# SampCert 4.30 compatibility patch.
#
# Vendors the changes our team's SampCert fork commit 9cb29f35 needs to build on the
# pinned Lean v4.30.0-rc2 stack: two proof fixes (Foundations/UniformByte.lean,
# Samplers/Uniform/Properties.lean) plus the 4.29->4.30 toolchain/mathlib bump
# (lean-toolchain, lakefile.lean, lake-manifest.json).
#
# Apply from the SampCert checkout root:  git -C SampCert apply <this file>
# (git apply ignores these leading comment lines.)
#
diff --git a/SampCert/Foundations/UniformByte.lean b/SampCert/Foundations/UniformByte.lean
index 88cfe62..6b96434 100644
--- a/SampCert/Foundations/UniformByte.lean
+++ b/SampCert/Foundations/UniformByte.lean
@@ -116,7 +116,7 @@ def probUniformByteUpperBits_eval_support {i x : ℕ} (Hx : x < 2 ^ (min 8 i)) :
       refine (ENNReal.toReal_eq_toReal_iff' ?G1 ?G2).mp this
       case G1 =>
         rw [tsum_eq_finsum ?G1]
-        case G1 => simp [Function.support, Set.toFinite (Set.univ : Set T)]
+        case G1 => exact Set.toFinite _
         simp
         have R := @finsum_induction ENNReal T _ (fun _ => 1) (fun z => z ≠ ⊤) (by simp) (by aesop) (by simp)
         simp at R
diff --git a/SampCert/Samplers/Uniform/Properties.lean b/SampCert/Samplers/Uniform/Properties.lean
index 4b15f3e..9695ad5 100644
--- a/SampCert/Samplers/Uniform/Properties.lean
+++ b/SampCert/Samplers/Uniform/Properties.lean
@@ -36,6 +36,8 @@ theorem rw1 (n : PNat) :
     dsimp [a]
     exact ENNReal.mul_ne_top (by simp) (by simp)
   simp
+  congr 1
+  rw [ENNReal.mul_inv (by simp) (by simp), inv_inv, mul_comm]
 
 theorem rw2 (n : PNat) : ((↑↑n)⁻¹ : ENNReal) = ((↑↑n)⁻¹ : NNReal) := by
   let a : ENNReal := (↑↑n)⁻¹
